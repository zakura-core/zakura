@@ -51,10 +51,14 @@ impl consensus::Parameters for TxblastNetworkParams {
 
     fn activation_height(&self, nu: NetworkUpgrade) -> Option<BlockHeight> {
         match self {
-            Self::LocalGenesis => match nu {
-                NetworkUpgrade::Nu6_1 => None,
-                _ => Some(BlockHeight::from_u32(1)),
-            },
+            // Every upgrade this build knows about is active from height 1,
+            // matching the activation table the config writer puts on the
+            // generated chain (see zebra_config.rs). These two must agree
+            // exactly: if the builder's newest active upgrade differs from the
+            // chain's, every transaction is rejected with "incorrect consensus
+            // branch id". Nu6_1 in particular is active on the chain, so it
+            // must not be excluded here.
+            Self::LocalGenesis => Some(BlockHeight::from_u32(1)),
             Self::PublicTestnet => consensus::Network::TestNetwork.activation_height(nu),
             Self::Mainnet => consensus::Network::MainNetwork.activation_height(nu),
         }
